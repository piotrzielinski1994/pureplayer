{
  "$schema": "https://biomejs.dev/schemas/2.5.5/schema.json",
  "extends": ["@pziel/pureui/biome"],
  "files": {
    "includes": [
      "!!**/dist",
      "!!**/node_modules",
      "!!**/src-tauri/target",
      "!!**/src-tauri/gen",
      "!!**/docs",
      "!!**/storybook-static"
    ]
  },
  "linter": {
    "rules": {
      "a11y": "off",
      "style": {
        "noNonNullAssertion": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/lib/settings/__tests__/tauri-store.test.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noConstructorReturn": "off"
          }
        }
      }
    }
  ]
}
